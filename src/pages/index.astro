---
import TrackerLayout from "../layouts/TrackerLayout.astro";
import indexMainRaw from "../html/index-main.html?raw";

// Fix relative image paths for mount-path deployment
const rawBase = import.meta.env.BASE_URL;
const b = rawBase.endsWith("/") ? rawBase : rawBase + "/";
// Replace all bare "img/" references (in src, srcset, after commas) with base-prefixed paths
const indexMain = indexMainRaw.replace(/(["=, ])img\//g, `$1${b}img/`);
---

<TrackerLayout
  title="Artemis II Mission Tracker"
  description="Track NASA's Artemis II crewed mission around the Moon in real time. Live telemetry, mission timeline, crew bios, and spacecraft data."
  variant="home"
  og={true}
  scripts="home"
>
  <Fragment set:html={indexMain} />
</TrackerLayout>
